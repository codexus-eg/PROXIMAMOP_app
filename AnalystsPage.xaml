<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PROXIMAMOP.Pages.AnalystsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:PROXIMAMOP.Models"
    Title="Analysts"
    BackgroundColor="#0B1020"
    FlowDirection="RightToLeft"
    Shell.NavBarIsVisible="False">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0B1020" Offset="0" />
                <GradientStop Color="#121A31" Offset="0.45" />
                <GradientStop Color="#1B1430" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid RowDefinitions="Auto,Auto,*" Padding="16,18,16,12">

            <Border
                Grid.Row="0"
                Background="#1A0B0B"
                Stroke="#D4AF37"
                StrokeThickness="2"
                Padding="16"
                StrokeShape="RoundRectangle 24">

                <VerticalStackLayout Spacing="6">
                    <Label
                        Text="Analysts"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="#F7E7A1" />

                    <Label
                        Text="قائمة المحللين"
                        FontSize="14"
                        TextColor="#F1E4B3" />
                </VerticalStackLayout>
            </Border>

            <Border
                Grid.Row="1"
                Margin="0,14,0,0"
                Background="#131A2C"
                Stroke="#283754"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 18"
                Padding="4">

                <SearchBar
                    x:Name="SearchBarControl"
                    Placeholder="ابحث عن محلل"
                    PlaceholderColor="#92A0C0"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    CancelButtonColor="#A78BFA"
                    TextChanged="OnSearchTextChanged" />
            </Border>

            <RefreshView
                Grid.Row="2"
                Margin="0,14,0,0"
                IsRefreshing="{Binding IsRefreshing}"
                Command="{Binding RefreshCommand}">

                <Grid>
                    <CollectionView
                        x:Name="AnalystsCollectionView"
                        ItemsSource="{Binding Analysts}"
                        SelectionMode="None">

                        <CollectionView.EmptyView>
                            <VerticalStackLayout
                                Padding="30,80"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Spacing="10">

                                <Label
                                    Text="لا يوجد محللون حالياً"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="White"
                                    HorizontalTextAlignment="Center" />

                                <Label
                                    Text="جرّب التحديث أو انتظر إضافة محللين من لوحة الأدمن"
                                    FontSize="14"
                                    TextColor="#AAB5D4"
                                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:AnalystListItemViewModel">
                                <Border
                                Margin="0,0,0,14"
                                    Padding="14"
                                    Stroke="#D4AF37"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 24">

                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#050505" Offset="0.0" />
                                            <GradientStop Color="#0B1F1A" Offset="0.5" />
                                            <GradientStop Color="#000000" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>

                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">

                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                            <Border
                                                WidthRequest="74"
                                                HeightRequest="74"
                                                Background="#0F0F0F"
                                                Stroke="#D4AF37"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 24">

                                                <Image
                                                    Source="{Binding AvatarUrl}"
                                                    Aspect="AspectFill" />
                                            </Border>

                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                Spacing="6"
                                                VerticalOptions="Center">

                                                <HorizontalStackLayout Spacing="8">
                                                    <Label
                                                        Text="{Binding Name}"
                                                        FontSize="18"
                                                        FontAttributes="Bold"
                                                        TextColor="White"
                                                        VerticalOptions="Center" />

                                                    <Border
                                                        IsVisible="{Binding HasBadge}"
                                                        Padding="6,2"
                                                        Stroke="{Binding BadgeBorderColor}"
                                                        StrokeThickness="1"
                                                        Background="{Binding BadgeIconBackgroundColor}"
                                                        StrokeShape="RoundRectangle 10"
                                                        VerticalOptions="Center">

                                                        <Label
                                                            Text="{Binding BadgeIcon}"
                                                            FontSize="12"
                                                            TextColor="{Binding BadgeIconTextColor}" />
                                                    </Border>
                                                </HorizontalStackLayout>

                                                <Label
                                                    Text="{Binding StarsText}"
                                                    FontSize="14"
                                                    TextColor="#F7C948" />
                                                    <Label
                                                    Text="{Binding Subtitle}"
                                                    FontSize="13"
                                                    TextColor="#D7E3D9"
                                                    LineBreakMode="TailTruncation"
                                                    MaxLines="1" />
                                            </VerticalStackLayout>

                                            <Button
                                                Grid.Column="2"
                                                Text="فتح"
                                                Clicked="OnOpenAnalystClicked"
                                                CommandParameter="{Binding Id}"
                                                HeightRequest="42"
                                                WidthRequest="74"
                                                CornerRadius="14"
                                                BackgroundColor="#8B5CF6"
                                                TextColor="White"
                                                FontAttributes="Bold"
                                                VerticalOptions="Center" />
                                        </Grid>

                                        <Label
                                            Grid.Row="1"
                                            Text="{Binding AnalystBio}"
                                            FontSize="14"
                                            TextColor="#E0E0E0"
                                            LineBreakMode="TailTruncation"
                                            MaxLines="3" />

                                        <HorizontalStackLayout
                                            Grid.Row="2"
                                            Spacing="8">

                                            <Border
                                                Padding="10,6"
                                                Background="{Binding FollowStateBackgroundColor}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 14">

                                                <Label
                                                    Text="{Binding FollowStateText}"
                                                    FontSize="12"
                                                    FontAttributes="Bold"
                                                    TextColor="{Binding FollowStateTextColor}" />
                                            </Border>

                                            <Border
                                                Padding="10,6"
                                                Background="{Binding NotificationStateBackgroundColor}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 14">

                                                <Label
                                                    Text="{Binding NotificationStateText}"
                                                    FontSize="12"
                                                    FontAttributes="Bold"
                                                    TextColor="{Binding NotificationStateTextColor}" />
                                            </Border>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Grid
                        x:Name="LoadingOverlay"
                        IsVisible="{Binding IsBusy}"
                        BackgroundColor="#70000000"
                        InputTransparent="False">

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Spacing="10">

                            <ActivityIndicator
                                IsRunning="True"
                                Color="#A78BFA"
                                WidthRequest="42"
                                HeightRequest="42" />

                            <Label
                                Text="جاري التحميل"
                                TextColor="White"
                                FontSize="14"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
            </RefreshView>
        </Grid>
    </Grid>
</ContentPage>