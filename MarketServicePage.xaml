<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="PROXIMAMOP.MarketServicePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#050505"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="42,*">

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                BackgroundColor="#0B0B0B"
                StrokeThickness="0"
                Padding="3,4">

            <Grid ColumnDefinitions="*,76"
                  ColumnSpacing="3"
                  VerticalOptions="Center">

                <ScrollView Grid.Column="0"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">

                    <HorizontalStackLayout Spacing="1"
                                           VerticalOptions="Center">

                        <Button x:Name="BtnM1"
                                Text="M1"
                                Clicked="OnTimeframeClicked"
                                CommandParameter="M1"
                                HeightRequest="24"
                                WidthRequest="28"
                                Padding="0"
                                CornerRadius="6"
                                FontSize="8"
                                BackgroundColor="#A78BFA"
                                TextColor="White" />

                        <Button x:Name="BtnM5"
                                Text="M5"
                                Clicked="OnTimeframeClicked"
                                CommandParameter="M5"
                                HeightRequest="24"
                                WidthRequest="28"
                                Padding="0"
                                CornerRadius="6"
                                FontSize="8"
                                BackgroundColor="#A78BFA"
                                TextColor="White" />

                        <Button x:Name="BtnM15"
                                Text="M15"
                                Clicked="OnTimeframeClicked"
                                CommandParameter="M15"
                                HeightRequest="24"
                                WidthRequest="32"
                                Padding="0"
                                CornerRadius="6"
                                FontSize="8"
                                BackgroundColor="#A78BFA"
                                TextColor="White" />

                        <Button x:Name="BtnM30"
                                Text="M30"
                                Clicked="OnTimeframeClicked"
                                CommandParameter="M30"
                                HeightRequest="24"
                                WidthRequest="32"
                                Padding="0"
                                CornerRadius="6"
                                FontSize="8"
                                BackgroundColor="#A78BFA"
                                TextColor="White" />

                        <Button x:Name="BtnH1"
                                Text="H1"
                                Clicked="OnTimeframeClicked"
                                CommandParameter="H1"
                                HeightRequest="24"
                                WidthRequest="28"
                                Padding="0"
                                CornerRadius="6"
                                FontSize="8"
                                BackgroundColor="#A78BFA"
                                TextColor="White" />

                        <Button x:Name="BtnH4"
                                Text="H4"
                                Clicked="OnTimeframeClicked"
                                CommandParameter="H4"
                                HeightRequest="24"
                                WidthRequest="28"
                                Padding="0"
                                CornerRadius="6"
                                FontSize="8"
                                BackgroundColor="#A78BFA"
                                TextColor="White" />

                        <Button x:Name="BtnD1"
                                Text="D1"
                                Clicked="OnTimeframeClicked"
                                CommandParameter="D1"
                                HeightRequest="24"
                                WidthRequest="28"
                                Padding="0"
                                CornerRadius="6"
                                FontSize="8"
                                BackgroundColor="#A78BFA"
                                TextColor="White" />

                    </HorizontalStackLayout>

                </ScrollView>

                <Button x:Name="SymbolButton"
                        Grid.Column="1"
                        Text="XAUUSD"
                        Clicked="OnSymbolClicked"
                        HeightRequest="30"
                        WidthRequest="76"
                        Padding="0"
                        CornerRadius="9"
                        FontSize="10"
                        FontAttributes="Bold"
                        BackgroundColor="#7C3AED"
                        TextColor="White" />

            </Grid>

        </Border>

        <!-- CHART -->
        <Grid Grid.Row="1"
              BackgroundColor="#050505">

            <WebView x:Name="ChartWebView"
                     BackgroundColor="#050505" />

            <!-- MARKET LABEL -->
            <Border HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,8,34"
                    WidthRequest="132"
                    HeightRequest="58"
                    BackgroundColor="#FF000000"
                    Stroke="#A78BFA"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 18"
                    InputTransparent="True"
                    ZIndex="10">

                <Label x:Name="MarketLabel"
                       Text="XAUUSD"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="#A78BFA"
                       FontSize="18"
                       FontAttributes="Bold" />

            </Border>

            <!-- LIVE + BACK -->
            <Grid HorizontalOptions="Start"
                  VerticalOptions="Start"
                  Margin="10,10,0,0"
                  RowDefinitions="Auto,Auto"
                  ZIndex="11">

                <!-- LIVE -->
                <Border Padding="8,4"
                        BackgroundColor="#99000000"
                        Stroke="#22C55E"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        InputTransparent="True">

                    <HorizontalStackLayout Spacing="5">

                        <Ellipse WidthRequest="7"
                                 HeightRequest="7"
                                 Fill="#22C55E"
                                 VerticalOptions="Center" />

                        <Label Text="LIVE"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#22C55E"
                               VerticalOptions="Center" />

                    </HorizontalStackLayout>

                </Border>

                <!-- BACK BUTTON -->
                <Border Grid.Row="1"
                Margin="14,4,0,0"
                        WidthRequest="22"
                        HeightRequest="22"
                        Background="#1A1114"
                        Stroke="#A78BFA"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        ZIndex="12">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>

                    <Label Text="←"
                           FontSize="11"
                           TextColor="#A78BFA"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

                </Border>

            </Grid>

            <!-- LOADING -->
            <Grid x:Name="LoadingOverlay"
                  IsVisible="False"
                  BackgroundColor="#88000000"
                  InputTransparent="False"
                  ZIndex="20">

                <Border WidthRequest="150"
                        HeightRequest="110"
                        BackgroundColor="#141016"
                        Stroke="#7C3AED"
                        StrokeThickness="1.4"
                        StrokeShape="RoundRectangle 22"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">

                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="10">

                        <ActivityIndicator IsRunning="True"
                                           Color="#A78BFA"
                                           WidthRequest="36"
                                           HeightRequest="36" />

                        <Label Text="Loading..."
                               TextColor="White"
                               FontSize="13"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />

                    </VerticalStackLayout>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>