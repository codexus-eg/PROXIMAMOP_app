<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PROXIMAMOP.FeedPage"
             BackgroundColor="#07110B"
             Shell.NavBarIsVisible="False"
             FlowDirection="RightToLeft">

    <Grid RowDefinitions="72,*"
          RowSpacing="0">

        <!-- Background -->
        <Image Grid.RowSpan="2"
               Source="feedbackground.jpg"
               Aspect="AspectFill"
               Opacity="0.38" />

        <Grid Grid.RowSpan="2">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CC06110B" Offset="0.0" />
                    <GradientStop Color="#AA0B1A12" Offset="0.45" />
                    <GradientStop Color="#CC08130D" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Top Bar -->
        <Border Grid.Row="0"
                BackgroundColor="#CC0E1712"
                Stroke="#2D5A41"
                StrokeThickness="0.8"
                Padding="16,10">

            <Grid ColumnDefinitions="Auto,*,Auto"
                  VerticalOptions="Center">

                <ActivityIndicator x:Name="LoadingIndicator"
                                   Grid.Column="0"
                                   IsVisible="False"
                                   IsRunning="False"
                                   Color="#86EFAC"
                                   WidthRequest="26"
                                   HeightRequest="26"
                                   VerticalOptions="Center" />

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="0"
                                     HorizontalOptions="End"
                                     VerticalOptions="Center">

                    <Label Text="Feed"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="End" />
                </VerticalStackLayout>

                <Border Grid.Column="2"
                        BackgroundColor="#10281C"
                        Stroke="#2D5A41"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="10,6"
                        Margin="10,0,0,0"
                        VerticalOptions="Center">

                    <Label x:Name="FeedCountLabel"
                           Text="0"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#86EFAC"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">

            <RefreshView x:Name="FeedRefreshView"
                         Refreshing="OnRefreshRequested"
                         BackgroundColor="Transparent"
                         RefreshColor="#86EFAC">

                <CollectionView x:Name="FeedCollectionView"
                                BackgroundColor="Transparent"
                                SelectionMode="None"
                                Margin="0"
                                ItemsLayout="VerticalList">

                    <CollectionView.EmptyView>
                        <Grid Padding="28">
                            <VerticalStackLayout Spacing="12"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                                 <Border BackgroundColor="#CC0E1712"
                                        Stroke="#2D5A41"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 20"
                                        Padding="22">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="لا توجد إشعارات حالياً"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="White"
                                               HorizontalTextAlignment="Center" />

                                        <Label Text="waiting"
                                               FontSize="14"
                                               TextColor="#B7D7C4"
                                               HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#CC0E1712"
                                    Stroke="#2D5A41"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 22"
                                    Margin="12,12,12,0"
                                    Padding="16">

                                <VerticalStackLayout Spacing="12">

                                    <!-- Header row -->
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">

                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="4"
                                                             HorizontalOptions="End">

                                            <Label Text="{Binding LocalTimeText}"
                                                   FontSize="12"
                                                   TextColor="#B7D7C4"
                                                   HorizontalTextAlignment="End" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1"
                                                BackgroundColor="#133323"
                                                Stroke="#2D5A41"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="10,5"
                                                VerticalOptions="Start">

                                            <Label Text="{Binding Id}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="#86EFAC"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Border>
                                    </Grid>

                                    <BoxView HeightRequest="1"
                                             Color="#244735" />

                                    <!-- Content -->
                                    <VerticalStackLayout Spacing="10">
                                    <Label Text="{Binding TitleLine}"
                                               FontSize="21"
                                               FontAttributes="Bold"
                                               TextColor="White"
                                               HorizontalTextAlignment="End"
                                               LineBreakMode="WordWrap"
                                               IsVisible="{Binding TitleLine, Converter={StaticResource StringNotEmptyConverter}}" />

                                        <Label Text="{Binding EntryLine}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#FACC15"
                                               HorizontalTextAlignment="End"
                                               LineBreakMode="WordWrap"
                                               IsVisible="{Binding EntryLine, Converter={StaticResource StringNotEmptyConverter}}" />

                                        <Label Text="{Binding TargetLine}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#4ADE80"
                                               HorizontalTextAlignment="End"
                                               LineBreakMode="WordWrap"
                                               IsVisible="{Binding TargetLine, Converter={StaticResource StringNotEmptyConverter}}" />

                                        <Label Text="{Binding StopLine}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#F87171"
                                               HorizontalTextAlignment="End"
                                               LineBreakMode="WordWrap"
                                               IsVisible="{Binding StopLine, Converter={StaticResource StringNotEmptyConverter}}" />

                                        <Label Text="{Binding OtherLines}"
                                               FontSize="16"
                                               TextColor="#E5E7EB"
                                               HorizontalTextAlignment="End"
                                               LineBreakMode="WordWrap"
                                               IsVisible="{Binding OtherLines, Converter={StaticResource StringNotEmptyConverter}}" />

                                    </VerticalStackLayout>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <Grid x:Name="BusyOverlay"
                  IsVisible="False"
                  BackgroundColor="#66040A07"
                  InputTransparent="False">

                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="12">

                    <ActivityIndicator IsRunning="True"
                                       Color="#86EFAC"
                                       WidthRequest="42"
                                       HeightRequest="42" />

                    <Label Text="جاري تحميل الفيد..."
                           TextColor="White"
                           FontSize="14"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>

        </Grid>
    </Grid>

</ContentPage>