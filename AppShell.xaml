<?xml version="1.0" encoding="UTF-8" ?>

<Shell
    x:Class="PROXIMAMOP.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PROXIMAMOP"
    xmlns:pages="clr-namespace:PROXIMAMOP.Pages"
    xmlns:livepages="clr-namespace:PROXIMAMOP.Features.Live"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="#0B0B16"
    Shell.TabBarForegroundColor="#9A8CFF"
    Shell.TabBarTitleColor="#9A8CFF"
    Shell.TabBarUnselectedColor="#7C7C98">

    <TabBar>

        <ShellContent
            Title="Home"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate local:MainPage}" />

        <ShellContent
            Title="Feed"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate local:FeedPage}" />

        <ShellContent
            Title="Chart"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate local:ChartPage}" />

        <ShellContent
            Title="Chat"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate local:ChatPage}" />

        

        <ShellContent
            Title="Analysts"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate pages:AnalystsPage}" />

    </TabBar>

</Shell>